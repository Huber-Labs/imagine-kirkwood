# Supabase — Civic Points + email login (copy to .env.local; never commit .env.local)
# Run migrations 001, 002, and 003_sync_v1_catalog.sql after creating your project.

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Server only — admin dashboard (Milestone 4). Do not expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Vercel: set all three vars for Production, then Redeploy from the Deployments tab.

# Dev-only Author Mode on /explore?author=true (also accepts ?calibrate=true)
# NEXT_PUBLIC_ENABLE_AUTHOR_MODE=true
# NEXT_PUBLIC_ENABLE_MAP_CALIBRATION=true
