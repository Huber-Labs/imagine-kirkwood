# Supabase — Civic Points + email login (copy to .env.local; never commit .env.local)
# Run migrations 001, 002, 003, and 004_add_shaded_street.sql after creating your project.

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
# Supabase dashboard may label this "publishable key" — either name works:
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_publishable_key

# Server only — admin dashboard (Milestone 4). Do not expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Vercel: set all three vars for Production (exact names below), then Redeploy.
# After deploy, verify: https://imaginekirkwood.com/api/health/supabase

# Dev-only Author Mode on /explore?author=true (also accepts ?calibrate=true)
# NEXT_PUBLIC_ENABLE_AUTHOR_MODE=true
# NEXT_PUBLIC_ENABLE_MAP_CALIBRATION=true

# Optional — email notification when someone submits an idea.
# If unset, submissions are still saved and reviewable at /admin.
# Get a key at resend.com; verify a sending domain to use your own "from" address.
# RESEND_API_KEY=re_your_key
# ADMIN_NOTIFICATION_EMAIL=you@example.com
# RESEND_FROM_EMAIL=Imagine Kirkwood <ideas@imaginekirkwood.com>
# NEXT_PUBLIC_SITE_URL=https://imaginekirkwood.com
